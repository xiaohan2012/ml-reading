	file = {Full Text PDF:/Users/mwcvitkovic/Zotero/storage/ZWRV8KEB/Schulte and Khosravi - 2012 - Learning graphical models for relational data via .pdf:application/pdf;Snapshot:/Users/mwcvitkovic/Zotero/storage/KFB399ZB/s10994-012-5289-4.html:text/html}
}

